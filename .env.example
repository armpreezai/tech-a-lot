# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_SHEET_ID: The ID of the Google Sheet for the portfolio data.
# Extract this from your Google Sheet URL (the long string between /d/ and /edit).
VITE_GOOGLE_SHEET_ID="1n09oPWMo4q2LmbLTbVEXT_mLFRduqvEyMFtrtjP2aU0"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_SHEET_ID: The ID of the public Google Sheet for the Portfolio.
# Found in the URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
VITE_GOOGLE_SHEET_ID="1n09oPWMo4q2LmbLTbVEXT_mLFRduqvEyMFtrtjP2aU0"

# VITE_CONTACT_FORM_WEB_APP_URL: The URL of the Google Apps Script Web App to handle contact form submissions.
# You need to deploy a Google Apps Script as a Web App and paste the URL here.
VITE_CONTACT_FORM_WEB_APP_URL=""
